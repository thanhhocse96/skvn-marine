{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "skvn-marine/accordion",
  "version": "1.2.1",
  "title": "SKVN Accordion",
  "category": "skvn-marine",
  "icon": "menu",
  "description": "Accessible accordion skeleton for SKVN Marine content.",
  "textdomain": "skvn-marine-blocks",
  "attributes": {
    "heading": {
      "type": "string",
      "default": "Accordion heading"
    },
    "tone": {
      "type": "string",
      "default": "default"
    },
    "spacing": {
      "type": "string",
      "default": "md"
    },
    "width": {
      "type": "string",
      "default": "content"
    },
    "ariaLabel": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false
  }
}