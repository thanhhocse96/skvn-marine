{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "skvn-marine/card-grid",
  "version": "1.2.1",
  "title": "SKVN Card Grid",
  "category": "skvn-marine",
  "icon": "grid-view",
  "description": "Governed responsive card grid for repeated SKVN layout sections.",
  "textdomain": "skvn-marine-blocks",
  "attributes": {
    "columns": {
      "type": "number",
      "default": 3
    },
    "mobileColumns": {
      "type": "number",
      "default": 1
    },
    "gap": {
      "type": "string",
      "default": "md"
    },
    "cardStyle": {
      "type": "string",
      "default": "default"
    },
    "inset": {
      "type": "string",
      "default": "md"
    },
    "contentAlign": {
      "type": "string",
      "default": "left"
    },
    "equalHeights": {
      "type": "boolean",
      "default": false
    }
  },
  "allowedBlocks": [
    "skvn-marine/card",
    "core/group"
  ],
  "supports": {
    "html": false
  }
}
